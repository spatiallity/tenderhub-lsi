# Backend environment variables
# Copy file ini menjadi .env dan sesuaikan nilainya

DATABASE_URL=postgresql+asyncpg://lsi:lsi_password@db:5432/lsi_tender

# INAPROC API - Daftar di https://data.inaproc.id untuk mendapatkan API key
INAPROC_API_KEY=your_inaproc_api_key_here
INAPROC_BASE_URL=https://data.inaproc.id

# Set ke false setelah memiliki INAPROC API key
USE_DUMMY_DATA=true

CACHE_TTL_MINUTES=15
CORS_ORIGINS=http://localhost:5173,http://localhost:80
