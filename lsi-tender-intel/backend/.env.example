# Backend environment variables — copy to .env and fill in values

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker):
DATABASE_URL=postgresql+asyncpg://lsi:lsi_password@db:5432/lsi_tender
# Production (Supabase direct connection):
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── INAPROC ───────────────────────────────────────────────────────────────────
INAPROC_API_KEY=your_inaproc_api_key_here
INAPROC_BASE_URL=https://data.inaproc.id
USE_DUMMY_DATA=true
CACHE_TTL_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: set to exact frontend URL(s), comma-separated, no trailing slash
# e.g. https://your-tenderhub.vercel.app,https://spatiallity-tenderhub.hf.space
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174

# ── Authentication (Supabase JWT) ─────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key (NOT the anon key) — never expose this client-side
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Set true ONLY for local development without Supabase JWT configured
SKIP_AUTH=false
